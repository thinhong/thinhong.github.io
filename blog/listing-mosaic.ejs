<%
// Blog index listing: poster cards (soft tile + one huge cropped motif, title below) in a mosaic.
// Cover art is PINNED per post via front matter `image:` pointing at a file in /img/blog-art/,
// and each post should pin the cover that matches its banner motif. Posts without `image:` fall
// back to the topic cover whose motif matches the shared topic banner, so the listing card and
// the post hero always agree (position-based variant cycling caused mismatches and is gone).
// Covers are baked SVG files (inline SVG would be escaped by the pandoc pass). Children are
// spans to avoid block-in-anchor nesting.
const known = ["modelling","code","academia","productivity","reflections","leadership"];
const labels = { modelling:"Modelling", code:"R & code", academia:"Academia", productivity:"Productivity", reflections:"Reflections", leadership:"Leadership" };
const bannerMatch = { modelling:1, code:1, academia:1, productivity:1, reflections:1, leadership:3 };
%>
<div class="blg-grid" id="blg-grid">
<% for (let i = 0; i < items.length; i++) {
     const item = items[i];
     const cat = (item.categories && item.categories.length) ? String(item.categories[0]) : "";
     const topic = (cat && known.indexOf(cat.toLowerCase()) >= 0) ? cat.toLowerCase() : "modelling";
     const n = items.length;
     const isLead = (i === 0);
     const cls = isLead ? (n >= 3 ? " blg-feat" : (n === 2 ? " blg-wide" : " blg-solo")) : "";
     let ds = "";
     if (item.date) { const d = new Date(item.date); if (!isNaN(d.getTime())) ds = d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" }); }
     const rt = item["reading-time"] ? item["reading-time"] : "";
     const cover = item.image ? item.image : "/img/blog-art/cover-" + topic + "-" + bannerMatch[topic] + ".svg";
%>
  <a class="blg-card blg-<%= topic %><%= cls %>" href="<%= item.path %>" data-topic="<%= topic %>">
    <span class="blg-img"><img class="blg-art" src="<%= cover %>" alt="" loading="lazy"></span>
    <span class="blg-metatop"><span class="blg-cat"><%= labels[topic] || (cat ? cat : "Notes") %></span><span class="blg-date"><%= ds %><%= (ds && rt) ? " · " : "" %><%= rt %></span></span>
    <span class="blg-cardname"><%= item.title %></span>
  </a>
<% } %>
</div>
